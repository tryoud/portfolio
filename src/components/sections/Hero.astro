---
const { site } = Astro.props;
const hero = site.hero ?? {};
const headline = hero.headline ?? "Hey, there";
const badgeText = hero.badgeText ?? "";
const portraitSrc = (hero.portraitSrc && String(hero.portraitSrc).trim()) || "/hero/Nikolas_Maerker_hero.webp";
const primaryCta = hero.primaryCta ?? { label: "Let's talk", href: "#contact" };
const secondaryCta = hero.secondaryCta ?? { label: "View work", href: "#work" };
const primaryHref = typeof primaryCta === "object" && primaryCta.href ? primaryCta.href : "#contact";
const primaryLabel = typeof primaryCta === "object" && primaryCta.label ? primaryCta.label : "Let's talk";
const secondaryHref = typeof secondaryCta === "object" && secondaryCta.href ? secondaryCta.href : "#work";
const secondaryLabel = typeof secondaryCta === "object" && secondaryCta.label ? secondaryCta.label : "View work";
const specialization = hero.specialization ?? "";
const specializationLines = Array.isArray(hero.specializationLines) && hero.specializationLines.length
  ? hero.specializationLines.map((line) => String(line).trim()).filter(Boolean)
  : [];
const specializationDesktopLines = Array.isArray(hero.specializationDesktopLines) && hero.specializationDesktopLines.length
  ? hero.specializationDesktopLines.map((line) => String(line).trim()).filter(Boolean)
  : [];
const specializationDesktopCompactLines = Array.isArray(hero.specializationDesktopCompactLines) && hero.specializationDesktopCompactLines.length
  ? hero.specializationDesktopCompactLines.map((line) => String(line).trim()).filter(Boolean)
  : [];
const specializationCopy = specialization || specializationLines.join(" ");
const decorativeHeadline = String(hero.decorativeHeadline ?? "Hey, there").trim();
const nameLine = site.name ?? "";
const roleLine = site.role ?? "";
const nameUpper = nameLine.toUpperCase().replace(/\s+/g, " ");
const roleUpper = roleLine.toUpperCase();
const roleSegments = roleUpper.split(/\s*·\s*/).filter(Boolean);
const roleDisplayLinesFallback = roleSegments.flatMap((seg) => seg.split(/\s+&\s+/).map((s) => s.trim()).filter(Boolean));
const roleLines = Array.isArray(hero.roleLines) && hero.roleLines.length ? hero.roleLines.map((l) => String(l).toUpperCase()) : roleDisplayLinesFallback;
const roleSubline = (hero.roleSubline && String(hero.roleSubline).trim()) || "";
const nameParts = nameLine.trim().split(/\s+/);
const firstNameUpper = nameParts[0] ? nameParts[0].toUpperCase() : nameUpper;
const lastNameUpper = nameParts.length > 1 ? nameParts.slice(1).join(" ").toUpperCase() : "";
const rawHeadline = String(headline || "").trim();
const headlineLinesSource = Array.isArray(hero.headlineLines) && hero.headlineLines.length
  ? hero.headlineLines
  : rawHeadline.includes(" für ")
    ? (() => {
        const [beforeFor, afterFor = ""] = rawHeadline.split(" für ");
        const afterForParts = afterFor.split(", ").map((part) => part.trim()).filter(Boolean);
        if (afterForParts.length > 1) {
          return [beforeFor, `für ${afterForParts[0]},`, afterForParts.slice(1).join(", ")];
        }
        return [beforeFor, `für ${afterFor}`];
      })()
    : rawHeadline.includes(" for ")
      ? (() => {
          const [beforeFor, afterFor = ""] = rawHeadline.split(" for ");
          const afterForParts = afterFor.split(", ").map((part) => part.trim()).filter(Boolean);
          if (afterForParts.length > 1) {
            return [beforeFor, `for ${afterForParts[0]},`, afterForParts.slice(1).join(", ")];
          }
          return [beforeFor, `for ${afterFor}`];
        })()
      : rawHeadline.split(/,\s*/);
const headlineLines = headlineLinesSource
  .map((part) => String(part).trim())
  .filter(Boolean);
const heroHeadlineLines = headlineLines.length ? headlineLines : [headline];
const mobileHeadlineLines = Array.isArray(hero.headlineMobileLines) && hero.headlineMobileLines.length
  ? hero.headlineMobileLines.map((line) => String(line).trim()).filter(Boolean).slice(0, 5)
  : heroHeadlineLines.slice(0, 5);
const tabletHeadlineLines = Array.isArray(hero.headlineTabletLines) && hero.headlineTabletLines.length
  ? hero.headlineTabletLines.map((line) => String(line).trim()).filter(Boolean)
  : heroHeadlineLines;
const decorativeParts = decorativeHeadline.split(/,\s*/);
const decorativeLeft = decorativeParts[0] ? `${decorativeParts[0]},` : "Hey,";
const decorativeRight = decorativeParts[1] ?? "there";
---

<section class="relative flex min-h-0 max-h-[800px] flex-col overflow-hidden pt-4 pb-3 md:min-h-[calc(100svh-5rem)] md:pt-8 md:pb-[clamp(0.5rem,1.5vw,1rem)]" aria-labelledby="hero-heading" data-hero-motion>
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-[var(--color-background-light)]" />
    <div
      class="hero-portrait-cloud absolute inset-0 opacity-100"
      style="background: radial-gradient(ellipse 65% 55% at 50% 38%, rgb(255, 248, 228) 0%, rgb(255, 244, 218) 30%, rgba(255, 242, 225, 0.4) 55%, transparent 72%);"
    />
  </div>

  <!-- Single centered container: max-w-7xl, no drift on ultra-wide -->
  <div class="relative mx-auto flex min-h-0 w-full max-w-6xl flex-1 flex-col px-4 sm:px-6">
    <h1 id="hero-heading" class="sr-only">{headline} — {nameLine}, {roleLine}</h1>

    <!-- Availability pill: left-mid, inside container -->
    {badgeText ? (
      <div class="relative z-20 flex shrink-0 justify-center pt-1 pb-1 md:absolute md:left-4 md:top-1/2 md:-translate-y-1/2 md:justify-start md:pt-0 md:pb-0 sm:left-6">
        <div class="inline-flex min-h-[40px] min-w-[40px] items-center gap-2 rounded-full border border-zinc-200/70 bg-white/95 px-3.5 py-2 shadow-sm sm:min-h-0 sm:min-w-0 sm:px-4 sm:py-2">
          <span class="relative flex h-2.5 w-2.5 shrink-0" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-amber-400 opacity-75" />
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-amber-500" />
          </span>
          <span class="text-xs font-medium tracking-wide text-zinc-700 sm:text-xs">{badgeText}</span>
        </div>
      </div>
    ) : null}

    <div class="relative z-10 mx-auto w-full max-w-5xl pt-3 text-center lg:hidden">
      <div class="mx-auto max-w-[20rem] sm:hidden">
        {(mobileHeadlineLines.length ? mobileHeadlineLines : heroHeadlineLines).map((line) => (
          <p class="font-display text-[clamp(1.72rem,7vw,2.45rem)] font-medium italic leading-[0.9] tracking-[-0.04em] text-zinc-900 whitespace-nowrap">
            {line}
          </p>
        ))}
      </div>
      <div class="mx-auto hidden max-w-[38rem] sm:block">
        {tabletHeadlineLines.map((line) => (
          <p class="font-display text-[clamp(2.5rem,5vw,3.4rem)] font-medium italic leading-[0.92] tracking-[-0.045em] text-zinc-900">
            {line}
          </p>
        ))}
      </div>
    </div>

    <div class="pointer-events-none absolute left-1/2 top-[34%] z-10 hidden -translate-x-1/2 translate-y-[20px] items-baseline justify-center gap-[clamp(2rem,28vw,26rem)] lg:flex lg:z-0 lg:top-[32%] xl:gap-[clamp(2.5rem,30vw,28rem)]" aria-hidden="true">
      <span class="hero-parallax font-display text-[clamp(2.5rem,8vw,10rem)] font-medium italic leading-tight tracking-[-0.02em] text-zinc-900/30" data-hero-layer="back">{decorativeLeft}</span>
      <span class="hero-parallax -translate-x-10 xl:-translate-x-14 2xl:-translate-x-16 font-display text-[clamp(2.5rem,8vw,10rem)] font-medium italic leading-tight tracking-[-0.02em] text-zinc-900/30" data-hero-layer="back">{decorativeRight}</span>
    </div>

    <!-- Portrait: centered, no offset; bottom fade preserved -->
    <div class="relative z-10 flex min-h-0 flex-1 flex-col items-center justify-center pt-3 pb-[clamp(0.25rem,1vw,0.5rem)] lg:py-0">
      <div class="hero-parallax-soft mx-auto mt-2 w-44 shrink-0 translate-x-[6px] translate-y-[6px] scale-[1.01] sm:mt-5 sm:w-64 sm:translate-x-[10px] sm:translate-y-[8px] sm:scale-[1.04] lg:mt-0 lg:w-[34rem] lg:translate-x-[40px] lg:translate-y-[60px] lg:scale-[1.2] xl:w-[min(440px,90vw)] [filter:drop-shadow(0_25px_50px_-12px_rgba(0,0,0,0.15))_drop-shadow(0_0_40px_-8px_rgba(0,0,0,0.08))]" data-hero-layer="portrait">
        <img
          src={portraitSrc}
          alt=""
          class="h-auto w-full object-contain object-center"
          width="480"
          height="640"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          style="-webkit-mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%); mask-image: linear-gradient(to bottom, rgba(0,0,0,1) 75%, rgba(0,0,0,0) 100%); -webkit-mask-size: cover; mask-size: cover;"
        />
      </div>
    </div>

    {specializationCopy ? (
      <div class="mx-auto mt-3 max-w-[18.75rem] px-2 text-center sm:max-w-[28rem] lg:hidden">
        {specializationDesktopCompactLines.length ? (
          <div class="space-y-0.5 text-center text-[clamp(0.75rem,3.1vw,0.94rem)] leading-[1.4] text-zinc-600 sm:text-[clamp(0.9rem,2.2vw,1.04rem)] sm:leading-[1.5]">
            {specializationDesktopCompactLines.map((line) => <p class="whitespace-nowrap">{line}</p>)}
          </div>
        ) : (
          <p class="text-[clamp(0.82rem,3.6vw,0.95rem)] leading-[1.45] text-zinc-600 [text-wrap:balance] sm:text-[clamp(0.95rem,2.3vw,1.08rem)] sm:leading-[1.5]">
            {specializationCopy}
          </p>
        )}
      </div>
    ) : null}

    {specializationCopy ? (
      <div class="hero-parallax pointer-events-none absolute top-[calc(60%+20px)] z-20 hidden -translate-y-1/2 text-right text-zinc-600 lg:block lg:left-[calc(50%+12.5rem)] lg:right-8 lg:text-[0.72rem] lg:leading-[1.55] xl:left-[calc(50%+13.5rem)] xl:right-10 xl:text-[0.8rem] 2xl:left-[calc(50%+14rem)] 2xl:right-12 2xl:text-[0.88rem]" data-hero-layer="copy">
        {specializationDesktopCompactLines.length ? (
          <>
            <div class="ml-auto w-max space-y-1 xl:hidden">
              {specializationDesktopCompactLines.map((line) => <p class="whitespace-nowrap">{line}</p>)}
            </div>
            <div class="ml-auto hidden w-max space-y-1 xl:block">
              {(specializationDesktopLines.length ? specializationDesktopLines : specializationDesktopCompactLines).map((line) => <p class="whitespace-nowrap">{line}</p>)}
            </div>
          </>
        ) : specializationDesktopLines.length ? (
          <div class="ml-auto w-max space-y-1">
            {specializationDesktopLines.map((line) => <p class="whitespace-nowrap">{line}</p>)}
          </div>
        ) : (
          <p class="[text-wrap:balance]">{specializationCopy}</p>
        )}
      </div>
    ) : null}

    <!-- Bottom band: 3-col grid, same baseline, within container -->
    <div class="relative z-20 shrink-0 px-0 pt-2 pb-0 sm:px-0 md:pt-3 md:pb-[clamp(0.5rem,1.5vw,1rem)]">
      <div class="grid w-full grid-cols-2 items-end gap-3 md:grid-cols-3 md:gap-8 lg:gap-10">
        <div class="flex min-w-0 flex-col items-start gap-0.5 md:gap-0">
          <span class="hidden select-none text-sm font-bold uppercase tracking-tight text-zinc-400 sm:block sm:text-lg md:text-lg lg:text-xl xl:text-2xl" aria-hidden="true">I AM</span>
          <span class="block text-[1.05rem] font-bold uppercase tracking-tight text-zinc-900 sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl 2xl:text-5xl" aria-hidden="true">{firstNameUpper}</span>
          {lastNameUpper ? <span class="block text-[1.05rem] font-bold uppercase tracking-tight text-zinc-900 sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl 2xl:text-5xl" aria-hidden="true">{lastNameUpper}</span> : null}
        </div>
        <div class="hidden items-end justify-self-center md:flex md:flex-col md:pb-1">
          <div class="flex flex-row justify-center gap-3 lg:gap-4">
            <a
              href={primaryHref}
              class="hero-primary-cta inline-flex min-h-[48px] items-center justify-center rounded-xl bg-[var(--accent)] px-5 py-3 text-sm font-medium text-[var(--accent-foreground)] shadow-md hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[var(--ring)] focus:ring-offset-2 focus:ring-offset-[var(--ring-offset)] transition-colors"
            >
              {primaryLabel}
            </a>
            <a
              href={secondaryHref}
              class="inline-flex min-h-[48px] items-center justify-center whitespace-nowrap rounded-xl border-2 border-zinc-900 px-5 py-3 text-sm font-medium text-zinc-900 hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-zinc-400 focus:ring-offset-2 transition-colors"
            >
              {secondaryLabel}
            </a>
          </div>
        </div>
        <div class="flex min-w-0 flex-col items-end gap-0.5 text-right">
          {roleLines.length ? roleLines.map((line) => (
            <span class="block text-[0.8rem] font-bold uppercase tracking-tight leading-tight text-zinc-900 sm:text-sm md:text-lg lg:text-xl xl:text-2xl" aria-hidden="true">{line}</span>
          )) : (
            <span class="block text-[0.8rem] font-bold uppercase tracking-tight leading-tight text-zinc-900 sm:text-sm md:text-lg lg:text-xl xl:text-2xl" aria-hidden="true">{roleUpper}</span>
          )}
          {roleSubline ? (
            <span class="mt-0.5 hidden text-xs font-medium uppercase tracking-wide text-zinc-500 sm:block sm:text-sm" aria-hidden="true">{roleSubline}</span>
          ) : null}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector("[data-hero-motion]");
    if (!section || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const backLayers = section.querySelectorAll('[data-hero-layer="back"]');
    const portrait = section.querySelector('[data-hero-layer="portrait"]');
    const copy = section.querySelector('[data-hero-layer="copy"]');
    let ticking = false;

    function update() {
      ticking = false;
      const rect = section.getBoundingClientRect();
      const viewport = window.innerHeight || 1;
      const progress = Math.max(-1, Math.min(1, (viewport * 0.5 - rect.top) / viewport));

      backLayers.forEach((el) => el.style.setProperty("--parallax-y", `${Math.round(progress * -24)}px`));
      if (portrait) portrait.style.setProperty("--parallax-soft-y", `${Math.round(progress * 16)}px`);
      if (copy) copy.style.setProperty("--parallax-y", `${Math.round(progress * -10)}px`);
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(update);
    }

    update();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  })();
</script>
