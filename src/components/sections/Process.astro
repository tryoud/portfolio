---
const { site } = Astro.props;
const process = site.process ?? {};
const heading = process.heading ?? "Seamless collaboration.";
const sectionLabel = process.sectionLabel ?? "How I work";
const steps = process.steps ?? [];
const stepList = Array.isArray(steps) && steps.length > 0
  ? steps.map((s) => (typeof s === "string" ? { title: s, description: "" } : { title: s.title ?? "", description: s.description ?? "" }))
  : [];
---

<section id="process" class="border-y border-zinc-100 bg-white py-16 md:py-20" aria-labelledby="process-heading" data-reveal-group>
  <div class="mx-auto max-w-6xl px-6">
    <div class="scroll-reveal mb-12 text-center md:mb-14" data-reveal="fade">
      <span class="mb-2 block text-sm font-semibold uppercase tracking-[0.18em] text-zinc-500">{sectionLabel}</span>
      <h2 id="process-heading" class="font-display text-4xl italic text-zinc-900 md:text-[3.25rem]">{heading}</h2>
    </div>
    <div class="relative grid grid-cols-1 gap-6 md:grid-cols-4 md:gap-7">
      <div class="absolute left-0 top-11 hidden h-px w-full bg-zinc-200 md:block" aria-hidden="true" />
      {stepList.map((step, i) => (
        <div class="scroll-reveal group relative z-10 rounded-2xl border border-zinc-200/70 bg-[#FDFBF7] p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-md md:border-none md:bg-transparent md:p-0 md:shadow-none md:hover:translate-y-0 md:hover:shadow-none" data-reveal="card" style={`--reveal-delay: ${Math.min(i * 120, 320)}ms;`}>
          <div class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full border border-zinc-200/70 bg-white shadow-sm transition-transform duration-300 group-hover:scale-105 md:mx-0">
            <span class="font-display text-2xl italic font-bold text-zinc-400">{String(i + 1).padStart(2, "0")}</span>
          </div>
          <h4 class="mb-2 text-center text-lg font-bold text-zinc-900 md:text-left md:text-[1.2rem]">{step.title}</h4>
          <p class="text-center text-sm leading-relaxed text-zinc-600 md:text-left">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector("#process[data-reveal-group]");
    if (!section || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const items = section.querySelectorAll(".scroll-reveal");
    if (!items.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.14, rootMargin: "0px 0px -8% 0px" });

    items.forEach((item) => observer.observe(item));
  })();
</script>
