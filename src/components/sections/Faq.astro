---
const { site } = Astro.props;
const faq = site.faq ?? {};
const sectionLabel = faq.sectionLabel ?? "FAQ";
const heading = faq.heading ?? "Häufige Fragen.";
const lead = faq.lead ?? "";
const items = Array.isArray(faq.items) ? faq.items.filter((item) => item?.q && item?.a) : [];
---

{items.length ? (
  <section id="faq" class="border-t border-zinc-100 bg-[#FDFBF7] py-16 md:py-20" aria-labelledby="faq-heading" data-reveal-group>
    <div class="mx-auto max-w-6xl px-6">
      <div class="scroll-reveal mb-10 md:mb-12" data-reveal="fade">
        <span class="mb-2 block text-sm font-semibold uppercase tracking-[0.18em] text-zinc-500">{sectionLabel}</span>
        <h2 id="faq-heading" class="font-display text-4xl italic text-zinc-900 md:text-[3.25rem]">{heading}</h2>
        {lead ? <p class="mt-4 max-w-xl text-sm leading-relaxed text-zinc-600 md:text-base">{lead}</p> : null}
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {items.map((item, index) => (
          <details
            class="scroll-reveal faq-item group rounded-2xl border border-zinc-200/70 bg-white shadow-sm transition-all duration-300 hover:border-zinc-300 open:border-zinc-300 open:shadow-md"
            data-reveal="card"
            style={`--reveal-delay: ${Math.min(index * 90, 360)}ms;`}
          >
            <summary class="flex min-h-[48px] cursor-pointer list-none items-center justify-between gap-4 rounded-2xl p-5 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-zinc-400 focus-visible:ring-offset-2 md:p-6">
              <span class="text-base font-bold text-zinc-900 md:text-lg">{item.q}</span>
              <span class="faq-chevron mt-0.5 shrink-0 text-zinc-400 transition-transform duration-300 group-open:rotate-45 group-hover:text-zinc-700" aria-hidden="true">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
              </span>
            </summary>
            <p class="px-5 pb-5 text-sm leading-relaxed text-zinc-600 md:px-6 md:pb-6 md:text-base">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
) : null}

<script>
  (function () {
    const section = document.querySelector("#faq[data-reveal-group]");
    if (!section || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const items = section.querySelectorAll(".scroll-reveal");
    if (!items.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.14, rootMargin: "0px 0px -8% 0px" });

    items.forEach((item) => observer.observe(item));
  })();
</script>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
